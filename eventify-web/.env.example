# auto = try backend API first, fallback to mock data if unavailable
# api = backend API only
# mock = mock-only
VITE_EVENTS_REPO_MODE=api

# Local backend (npm start in Eventify/)
VITE_API_BASE_URL=http://localhost:3000
# If frontend and API are deployed in the same Vercel project, use:
# VITE_API_BASE_URL=/api
VITE_DEFAULT_LAT=50.8503
VITE_DEFAULT_LNG=4.3517
VITE_EVENTS_FETCH_SIZE=80

# Keep service worker off by default to avoid stale chunk issues after deploys.
# Set to true only if you explicitly want offline caching.
VITE_ENABLE_SW=false
