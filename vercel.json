{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/api"
    }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    },
    "api/[...all].js": {
      "maxDuration": 60
    },
    "api/cron/sync.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 * * * *"
    }
  ]
}
