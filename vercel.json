{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 60
    },
    "api/[...all].js": {
      "maxDuration": 60
    },
    "api/cron/sync.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/sync",
      "schedule": "0 * * * *"
    }
  ],
  "routes": [
    {
      "src": "^/api/?$",
      "dest": "/api/index.js"
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/[...all].js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
