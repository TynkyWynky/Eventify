PORT=3000
NODE_ENV=development
TRUST_PROXY=0
JSON_BODY_LIMIT=100kb
JWT_SECRET=replace_with_a_long_random_secret_of_at_least_32_chars
JWT_EXPIRES_IN=7d
JWT_ISSUER=eventify-api
JWT_AUDIENCE=eventify-client
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_LOCALHOST_ANY_PORT=false
# Emergency fallback for CORS debugging (set true only if needed)
CORS_ALLOW_ALL=false
# Allow https://*.vercel.app origins when running on Vercel (useful for Preview deployments)
CORS_ALLOW_VERCEL_APP=true
AUTH_LOGIN_WINDOW_MS=900000
AUTH_LOGIN_MAX_ATTEMPTS=10
AUTH_REGISTER_WINDOW_MS=3600000
AUTH_REGISTER_MAX_ATTEMPTS=5
SOCIAL_WRITE_WINDOW_MS=60000
SOCIAL_WRITE_MAX_ATTEMPTS=60
INVITE_WINDOW_MS=3600000
INVITE_MAX_ATTEMPTS=30
LLM_PROVIDER=openai
LLM_ENABLED=true
LLM_API_KEY=
OPENAI_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_MS=5500
LLM_MAX_MESSAGE_CHARS=1200
CHATBOT_FAST_ONLY=false
CHATBOT_TIMEOUT_MS=12000
CHATBOT_CACHE_TTL_MS=120000
CHATBOT_MAX_REPLY_CHARS=1400
# Legacy Ollama keys are still supported as fallback:
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
TICKETMASTER_API_KEY=your_ticketmaster_key
SETLISTFM_API_KEY=your_setlistfm_key
SCRAPE_ENABLED=true
SCRAPE_SOURCE_URLS=https://www.eventbrite.com/d/belgium--brussels/music--events/,https://www.eventbrite.com/d/belgium--antwerp/music--events/
SCRAPE_MAX_EVENTS=40
SCRAPE_MAX_EVENTS_PER_SOURCE=25
SCRAPE_MAX_LINKS_PER_SOURCE=20
SCRAPE_TIMEOUT_MS=12000
SCRAPE_SOURCE_CONCURRENCY=3
SCRAPE_CACHE_TTL_MS=900000
SCRAPE_REQUEST_WAIT_MS=2500
# Extra wait budget used by internal sync calls so scraped sources can warm before DB upsert.
SCRAPE_SYNC_WAIT_MS=25000
SCRAPE_USER_AGENT=EventifyScraper/1.0 (+https://example.com/eventify; educational-project)
SCRAPE_ALLOWED_COUNTRIES=
SCRAPE_ALLOWED_CITIES=
SCRAPE_SONGKICK_OFFICIAL_LOOKUP=true
SCRAPE_SONGKICK_OFFICIAL_ENRICH_LIMIT=12
SCRAPE_SONGKICK_TICKET_TIMEOUT_MS=10000
SCRAPE_OFFICIAL_PAGE_TIMEOUT_MS=10000
SCRAPE_ENABLE_OFFICIAL_PAGE_ENRICHMENT=true
SCRAPE_EVENTBRITE_DETAIL_LOOKUP=true
SCRAPE_EVENTBRITE_DETAIL_ENRICH_LIMIT=8
SCRAPE_EVENTBRITE_DETAIL_TIMEOUT_MS=10000
PRICE_ENRICH_ENABLED=true
PRICE_ENRICH_MAX_PER_REQUEST=12
PRICE_ENRICH_TICKETMASTER_MAX_PER_REQUEST=12
PRICE_ENRICH_CONCURRENCY=4
PRICE_ENRICH_TIMEOUT_MS=4500
PRICE_ENRICH_USER_AGENT=Mozilla/5.0
PRICE_ENRICH_BACKGROUND_ENABLED=true
PRICE_ENRICH_BACKGROUND_DELAY_MS=2000
PRICE_ENRICH_BACKGROUND_MAX_QUEUE=250
PRICE_ENRICH_CACHE_TTL_MS=21600000
PRICE_ENRICH_BLOCK_TTL_MS=600000
# Optional: Ticketmaster fallback via anti-bot capable fetch proxy
# (direct TM pages often return 401/403 to serverless IP ranges).
# Important: simple text mirrors (e.g. r.jina.ai/http://) are often still blocked by Ticketmaster.
PRICE_ENRICH_TICKETMASTER_PROXY_BASE_URL=
PRICE_ENRICH_TICKETMASTER_PROXY_TIMEOUT_MS=10000
TICKETMASTER_PRICE_INFERENCE_ENABLED=true
TICKETMASTER_PRICE_INFERENCE_MAX_SAMPLES_PER_KEY=24
TICKETMASTER_PRICE_INFERENCE_MAX_KEYS_PER_BUCKET=600
TICKETMASTER_PRICE_INFERENCE_MIN_TITLE_SAMPLES=2
TICKETMASTER_PRICE_INFERENCE_MIN_ARTIST_SAMPLES=2
TICKETMASTER_PRICE_INFERENCE_MIN_VENUE_SAMPLES=2
TICKETMASTER_PRICE_INFERENCE_MIN_PROMOTER_SAMPLES=2
TICKETMASTER_PRICE_INFERENCE_MIN_CITY_CATEGORY_SAMPLES=3
TICKETMASTER_PRICE_INFERENCE_MIN_CATEGORY_SAMPLES=4
TICKETMASTER_PRICE_INFERENCE_MIN_CITY_SAMPLES=4
TICKETMASTER_PRICE_INFERENCE_MIN_GLOBAL_SAMPLES=6
TICKETMASTER_PRICE_INFERENCE_STRICT_MODE=true
TICKETMASTER_PRICE_INFERENCE_MAX_SPREAD_RATIO=1.8
TICKETMASTER_PRICE_INFERENCE_ALLOW_BROAD_BUCKETS=false
TICKETMASTER_PRICE_INFERENCE_ALLOW_GLOBAL_BUCKET=false
TICKETMASTER_PRICE_INFERENCE_DB_SEED_ENABLED=true
TICKETMASTER_PRICE_INFERENCE_DB_SEED_TTL_MS=600000
TICKETMASTER_PRICE_INFERENCE_DB_SEED_MAX_ROWS=3000

# Sync service configuration
# Use a managed Postgres in production (Neon/Supabase/Render/RDS).
DATABASE_URL=postgres://events_user:events_password@localhost:5432/events_db
# Optional compatibility keys (Neon/Vercel integration usually provides these):
POSTGRES_URL=
POSTGRES_PRISMA_URL=
# Local docker Postgres: false | Managed Postgres: require
DATABASE_SSL=false
# Local sync worker: http://localhost:3000
# Vercel cron endpoint: leave empty to auto-resolve to https://<deployment>/api
API_BASE_URL=
CRON_SECRET=replace_with_a_long_random_secret
# Auto-run one sync when a fresh deployment receives its first API request (Vercel serverless)
SYNC_ON_DEPLOY=false
# If true, first API request waits for sync attempt (recommended true for guaranteed warm DB)
SYNC_ON_DEPLOY_BLOCKING=true
# Safety timeout for deploy-sync attempt (ms)
SYNC_ON_DEPLOY_TIMEOUT_MS=45000
SYNC_INTERVAL=0 * * * *
DEFAULT_LAT=50.8503
DEFAULT_LNG=4.3517
DEFAULT_RADIUS_KM=50
FETCH_SIZE=50
SYNC_USER_ID=1
